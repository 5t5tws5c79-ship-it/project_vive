# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요.  cp .env.example .env
# .env 는 gitignore 대상이라 커밋되지 않습니다. 실제 키를 여기(.env.example)에 넣지 마세요.

# 카카오 지도 JavaScript 키.
# 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키 > JavaScript 키.
# 콘솔의 플랫폼 > Web 사이트 도메인에 http://localhost:5173 을 등록해야 지도가 뜹니다.
VITE_KAKAO_KEY=d74c36c31f91f5e427b72b52936e6a27

# OpenAI API 키 (챗봇). VITE_ 프리픽스가 붙어야 브라우저에서 읽힙니다.
# 주의: 브라우저 직접 호출 방식이라 이 키는 클라이언트 번들에 노출됩니다.
#       배포 시에는 반드시 사용량/결제 한도를 건 전용 키를 사용하세요.
VITE_OPENAI_API_KEY=sk-your_openai_api_key
